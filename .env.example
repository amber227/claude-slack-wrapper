# Slack Bot Configuration
SLACK_APP_TOKEN=xapp-1-AXXXXXXXXXX-XXXXXXXXXXXXX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_BOT_TOKEN=xoxb-XXXXXXXXXXXX-XXXXXXXXXXXXX-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL=#your-channel-name

# File outbox - directories to monitor for new files (comma-separated relative paths)
# Set to '.' to watch working directory root, or specify multiple: '.,screenshots,outputs'
FILE_OUTBOX=.

# File extensions to watch in FILE_OUTBOX (comma-separated, use '*' for all files)
# Examples: '.png,.jpg,.gif' or '*'
FILE_OUTBOX_EXTENSIONS=.png,.jpg,.jpeg,.gif,.bmp,.webp

# Directory for downloaded Slack attachments (relative to working directory)
FILE_INBOX=file_inbox
